{
  "name": "goberna-club",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "npm --prefix frontend start",
    "dev:frontend": "npm --prefix frontend start",
    "dev:backend": "npm run start:dev --workspace backend",
    "backend:start": "npm run start:dev --workspace backend",
    "test:frontend": "npm --prefix frontend test",
    "test:backend": "npm run test --workspace backend",
    "lint:backend": "npm run lint --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate:dev": "npm run prisma:migrate:dev --workspace backend"
  }
}
