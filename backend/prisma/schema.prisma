generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  role           String    @default("CONSULTANT") // ADMIN | CONSULTANT | VISITOR
  plan           String?   // CONSULTOR_POLITICO | CONSULTOR_POLITICO_SENIOR | CONSULTOR_POLITICO_MASTER | CONSULTOR_POLITICO_INTERNACIONAL
  firstName      String
  lastName       String
  avatarUrl      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  deactivatedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profiles          ConsultantProfile[]
  refreshSessions   RefreshSession[]
  passwordResets    PasswordResetToken[]
  auditLogs         AuditLog[]          @relation("AuditActor")
  adminComments     AdminComment[]

  @@map("users")
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

// ─── Catalogs ────────────────────────────────────────────────────

model Country {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  profiles ConsultantProfile[]

  @@map("countries")
}

model Specialty {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  profiles ConsultantProfile[]

  @@map("specialties")
}

model Skill {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  profileSkills ProfileSkill[]

  @@map("skills")
}

// ─── Consultant Profile ──────────────────────────────────────────

model ConsultantProfile {
  id                    String    @id @default(cuid())
  userId                String
  slug                  String    @unique
  status                String    @default("DRAFT") // DRAFT | IN_REVIEW | PUBLISHED | REJECTED | ARCHIVED
  professionalHeadline  String?
  specialtyId           String?
  bio                   String?   @db.Text
  countryId             String?
  country               String?
  city                  String?
  modalities            String?   // comma-separated
  yearsOfExperience     Int?
  publicEmail           String?
  publicPhone           String?
  websiteUrl            String?
  facebookUrl           String?
  linkedinUrl           String?
  xUrl                  String?
  instagramUrl          String?
  featuredFlag          Boolean   @default(false)
  publishedAt           DateTime?
  submittedForReviewAt  DateTime?
  lastReviewedAt        DateTime?
  archivedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner         User       @relation(fields: [userId], references: [id])
  specialty     Specialty? @relation(fields: [specialtyId], references: [id])
  countryRef    Country?   @relation(fields: [countryId], references: [id])

  experiences   ProfileExperience[]
  educations    ProfileEducation[]
  languages     ProfileLanguage[]
  skills        ProfileSkill[]
  certificates  ProfileCertificate[]
  awards        ProfileAward[]
  assets        ProfileMediaAsset[]
  reviews       ProfileReview[]
  adminComments AdminComment[]

  @@map("consultant_profiles")
}

// ─── Profile Sub-Models ──────────────────────────────────────────

model ProfileExperience {
  id             String    @id @default(cuid())
  profileId      String
  company        String
  roleTitle      String
  employmentMode String?
  country        String?
  startDate      DateTime?
  endDate        DateTime?
  isCurrent      Boolean   @default(false)
  description    String?   @db.Text
  orderIndex     Int       @default(0)
  createdAt      DateTime  @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])

  @@map("profile_experiences")
}

model ProfileEducation {
  id           String    @id @default(cuid())
  profileId    String
  institution  String
  degree       String?
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  description  String?   @db.Text
  orderIndex   Int       @default(0)
  createdAt    DateTime  @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])

  @@map("profile_educations")
}

model ProfileLanguage {
  id               String   @id @default(cuid())
  profileId        String
  languageCode     String
  proficiencyLevel String
  createdAt        DateTime @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])

  @@map("profile_languages")
}

model ProfileSkill {
  id        String   @id @default(cuid())
  profileId String
  skillId   String?
  name      String
  years     Int?
  createdAt DateTime @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])
  skill   Skill?            @relation(fields: [skillId], references: [id])

  @@map("profile_skills")
}

model ProfileCertificate {
  id            String    @id @default(cuid())
  profileId     String
  title         String
  issuer        String?
  issueDate     DateTime?
  credentialUrl String?
  assetId       String?   @unique
  createdAt     DateTime  @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])
  asset   ProfileMediaAsset? @relation(fields: [assetId], references: [id])

  @@map("profile_certificates")
}

model ProfileAward {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  issuer      String?
  year        Int?
  description String?  @db.Text
  createdAt   DateTime @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])

  @@map("profile_awards")
}

model ProfileMediaAsset {
  id               String    @id @default(cuid())
  profileId        String
  type             String    // AVATAR | GALLERY_IMAGE | CERTIFICATE_FILE | SUPPORTING_DOC
  storageKey       String
  mimeType         String
  sizeBytes        BigInt
  originalFilename String
  publicUrl        String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())

  profile     ConsultantProfile  @relation(fields: [profileId], references: [id])
  certificate ProfileCertificate?

  @@map("profile_media_assets")
}

// ─── Reviews & Admin ─────────────────────────────────────────────

model ProfileReview {
  id             String   @id @default(cuid())
  profileId      String
  reviewerUserId String?
  fromStatus     String
  toStatus       String
  decision       String   // SUBMITTED | APPROVED | REJECTED | CHANGES_REQUESTED | UNPUBLISHED
  comment        String?  @db.Text
  createdAt      DateTime @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])

  @@map("profile_reviews")
}

model AdminComment {
  id          String   @id @default(cuid())
  profileId   String
  adminUserId String
  message     String   @db.Text
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  profile ConsultantProfile @relation(fields: [profileId], references: [id])
  admin   User              @relation(fields: [adminUserId], references: [id])

  @@map("admin_comments")
}

// ─── Clients (Contact Form) ─────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String
  country   String
  message   String?  @db.Text
  createdAt DateTime @default(now())

  @@map("clients")
}

// ─── Audit ───────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  actorRole    String?
  action       String
  resourceType String
  resourceId   String
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@map("audit_logs")
}
